{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "node",

    "types": ["node"],

    "sourceMap": true,

    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true
  },

  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}