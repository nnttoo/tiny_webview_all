{
  "title": "Webview Ipc",
  "width": 900,
  "height": 700,
  "is_frameless": false,
  "is_resizable": true,
  "is_maximize": false,
  "is_debug": true,
  "is_always_ontop": false,
  "is_fullscreen": false,
  "public_folder": "../examples/webview_ts_dev/html/",
  "list_command": {
    "printtime": {
      "executable": "cmd.exe",
      "args": [
        "/C",
        "echo  %TIME%"
      ]
    },
    "ping": {
      "executable": "cmd.exe",
      "args": [
        "/C",
        "ping google.com -t"
      ]
    }
  }
}